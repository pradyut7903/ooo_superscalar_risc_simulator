{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build pipeline_sim",
            "type": "shell",
            "command": "C:/msys64/ucrt64/bin/g++.exe",
            "args": [
                "-std=c++17",
                "-I", "include",
                "-o", "build/pipeline_sim.exe",
                "src/main.cpp",
                "src/processor.cpp",
                "src/reservation_station.cpp",
                "src/register_alias_table.cpp",
                "src/reorder_buffer.cpp",
                "src/instruction_fetch_queue.cpp",
                "src/execution_engine.cpp",
                "src/load_store_queue.cpp",
                "src/return_address_stack.cpp",
                "src/gshare_predictor.cpp"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
            "options": {
                "cwd": "${workspaceFolder}"
            }
        },
        {
            "label": "run pipeline_sim",
            "type": "shell",
            "command": "${workspaceFolder}/build/pipeline_sim.exe",
            "args": ["traces/sample.trace"],
            "dependsOn": ["build pipeline_sim"],
            "group": "test",
            "problemMatcher": []
        }
    ]
}
